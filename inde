            this.innerText = 'TIẾP TỤC LÀM BÀI';
        } else {
            this.innerText = 'TẠM DỪNG ⏸️';
            timerInterval = setInterval(() => {
                timeRemaining--;
                let mins = Math.floor(timeRemaining / 60);
                let secs = timeRemaining % 60;
                document.getElementById('timer').innerText = `${mins}:${secs < 10 ? '0' + secs : secs}`;
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    alert("Đã hết giờ làm bài! Bạn vẫn có thể tiếp tục làm nhưng nhớ cân đối thời gian thực tế phòng thi nha.");
                }
            }, 1000);
        }
    };

    // PROGRESS TRACKING
    let correctCount = 0;
    const totalQuestions = 13;
    const answeredSet = new Set();

    function updateProgress() {
        let percent = (answeredSet.size / totalQuestions) * 100;
        document.getElementById('progress-fill').style.width = percent + '%';
    }

    // SCROLL & HIGHLIGHT ON DEMAND (CHỈ GẠCH CHÂN KHI BẤM NÚT ĐỊNH VỊ)
    function scrollLeftTo(elementId) {
        const el = document.getElementById(elementId);
        if (el) {
            document.querySelectorAll('.evidence-mark').forEach(item => item.classList.remove('active-evidence'));
            el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            el.classList.add('active-evidence');
            setTimeout(() => { el.classList.remove('active-evidence'); }, 3000);
        }
    }

    function toggleTranslation(id) {
        const el = document.getElementById(id);
        el.style.display = el.style.display === 'block' ? 'none' : 'block';
    }

    // INTERACTIVE CONTROLS
    function checkSelectQuestion(selectEl) {
        const card = selectEl.closest('.question-card');
        const correctAns = card.dataset.ans;
        if (!selectEl.value || selectEl.disabled) return;
        selectEl.disabled = true;

        if (selectEl.value === correctAns) {
            selectEl.classList.add('correct');
            playAudio('success');
            confetti({ particleCount: 40 });
            correctCount++;
        } else {
            selectEl.classList.add('wrong');
            playAudio('fail');
            selectEl.value = correctAns;
            selectEl.classList.add('correct');
        }
        card.querySelector('.explanation-block').style.display = 'block';
        answeredSet.add(card.querySelector('.question-text').innerText);
        updateProgress();
    }

    function checkSingleGap(id) {
        const inputEl = document.getElementById(id);
        const card = inputEl.closest('.question-card');
        const correctAns = card.dataset.ans.toLowerCase();
        const userAns = inputEl.value.trim().toLowerCase();

        if(!userAns || inputEl.disabled) return;
        inputEl.disabled = true;

        if(userAns === correctAns) {
            inputEl.classList.add('correct');
            playAudio('success');
            confetti({ particleCount: 30 });
            correctCount++;
        } else {
            inputEl.classList.add('wrong');
            playAudio('fail');
            inputEl.value = card.dataset.ans;
            inputEl.classList.add('correct');
        }
        card.querySelector('.explanation-block').style.display = 'block';
        answeredSet.add(id);
        updateProgress();
    }

    // TEXT SELECTION AUTO-HIGHLIGHT
    document.addEventListener('mouseup', function() {
        let sel = window.getSelection();
        if (sel.rangeCount > 0 && sel.toString().trim().length > 0) {
            let node = document.createElement("span");
            node.className = "user-highlight";
            let range = sel.getRangeAt(0).cloneRange();
            try { range.surroundContents(node); sel.removeAllRanges(); } catch(e){}
        }
    });

    function submitExam() {
        if(timerInterval) clearInterval(timerInterval);
        document.getElementById('summary-modal').style.display = 'flex';
        document.getElementById('final-score').innerText = `${correctCount}/${totalQuestions}`;
        let txt = document.getElementById('result-text');
        if(correctCount >= 9) {
            txt.innerText = "Tuyệt vời ông mặt trời! Kỹ năng xử lý bài toán Ngôn ngữ học siêu đẳng cấp, xứng danh học trò xuất chúng của cô Hằng!";
        } else {
            txt.innerText = "Làm tốt lắm con ơi! Hãy nhấn lại nút 'Định vị dẫn chứng' ở những câu làm sai để ghi nhớ từ vựng và cấu trúc song hành nhé!";
        }
        confetti({ particleCount: 150, spread: 80 });
    }
</script>
</body>
</html>
